{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "Co-Authored-By": false,
  "attribution": { "commit": "", "pr": "" },
  "permissions": {
    "allow": [
      "Skill(cfg)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git mv *)",
      "Bash(git restore *)",
      "Bash(git ls-tree *)",
      "Bash(config *)",
      "Bash(tree *)",
      "WebSearch",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__ide__getDiagnostics"
    ],
    "ask": ["Bash(git push *)", "Bash(git publish *)", "Bash(rm *)"],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ],
    "defaultMode": "plan"
  },
  "skipDangerousModePermissionPrompt": true,
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["~/workspace", "//tmp/claude"],
      "denyRead": ["~/.ssh", "**/.env", "**/.env.*"],
      "denyWrite": ["~/.ssh", "**/.env", "**/.env.*"]
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/kokoro-speak || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/kokoro-speak || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/kokoro-speak || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-code-docs/claude-docs-helper.sh hook-check"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"$HOME/.bun/bin/bun\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": false,
    "claude-hud@claude-hud": true,
    "commit-commands@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": false,
    "typescript-lsp@claude-plugins-official": false,
    "context7@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest"
}
